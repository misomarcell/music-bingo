{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/index.html",
          "/*.css",
          "/*.js",
          "/manifest.json",
          "/manifest.webmanifest",
          "/favicon.ico",
          "/icons/*.png"
        ]
      }
    },
    {
      "name": "library-metadata",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/sources/songs/**"]
      }
    },
    {
      "name": "album-covers",
      "installMode": "lazy",
      "updateMode": "lazy",
      "resources": {
        "files": ["/album-covers/**"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "commit-info",
      "urls": ["https://api.github.com/repos/misomarcell/music-bingo/commits/main"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 1,
        "maxAge": "1h",
        "timeout": "5s"
      }
    },
    {
      "name": "google-fonts-stylesheets",
      "urls": ["https://fonts.googleapis.com/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 20,
        "maxAge": "7d",
        "timeout": "5s"
      }
    },
    {
      "name": "google-fonts-webfonts",
      "urls": ["https://fonts.gstatic.com/**"],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 40,
        "maxAge": "365d"
      }
    }
  ]
}
